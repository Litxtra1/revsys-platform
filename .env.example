# ==============================
# Application
# ==============================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==============================
# Supabase
# ==============================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ==============================
# Cross-app session sharing
# ==============================
# Parent domain the Supabase auth cookie is scoped to (e.g. ".revsys.ai"),
# so a session started on the marketing app is also seen by the dashboard
# app on its own subdomain. Leave unset in dev — localhost can't take an
# explicit Domain attribute, so cookies stay host-only there, which is
# already correct for local development.
AUTH_COOKIE_DOMAIN=

# ==============================
# Monitoring
# ==============================
NEXT_PUBLIC_SENTRY_DSN=
