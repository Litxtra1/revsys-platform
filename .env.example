# ==============================
# Application
# ==============================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==============================
# Supabase
# ==============================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ==============================
# Cookies
# ==============================
# Parent domain the Supabase auth cookie is scoped to (e.g. ".revsys.ai").
# Leave unset in dev — localhost can't take an explicit Domain attribute,
# so cookies stay host-only there, which is already correct for local
# development.
AUTH_COOKIE_DOMAIN=

# ==============================
# Shopify OAuth (read-only scopes only — see packages/shared/src/shopify)
# ==============================
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_REDIRECT_URI=http://localhost:3000/auth/shopify/callback

# ==============================
# Monitoring
# ==============================
NEXT_PUBLIC_SENTRY_DSN=
