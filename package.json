{
  "name": "revsys-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Revsys AI — Revenue Intelligence Operating System",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
